# ============================================
# VARIAVEIS DE AMBIENTE - Budget Free Engine
# ============================================
# INSTRUCOES PARA DESENVOLVIMENTO LOCAL
# Copie este arquivo para .env e preencha os valores
#
#   cp .env.example .env
#
# Nao commite .env em seu repositorio!
# ============================================

# ─────────────────────────────────────────────
# AMBIENTE
# ─────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────
# APLICACAO
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com

# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
# Obtenha em: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
# Obtenha em: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# ─────────────────────────────────────────────
# CRON JOBS
# ─────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=gere-com-openssl-rand-hex-32
SESSION_TTL_DAYS=7

# ─────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_[KEY]
RESEND_FROM_EMAIL=no-reply@orcamentogratuito.tech

# ─────────────────────────────────────────────
# SENTRY (error monitoring — opcional em dev)
# ─────────────────────────────────────────────
# Criar projeto em https://sentry.io — ver PENDING-ACTIONS.md
# SENTRY_DSN=https://[public_key]@[org].ingest.sentry.io/[project]
# NEXT_PUBLIC_SENTRY_DSN=https://[public_key]@[org].ingest.sentry.io/[project]
# SENTRY_ENVIRONMENT=production
# SENTRY_ORG=your-org
# SENTRY_PROJECT=budget-free-tech
# SENTRY_AUTH_TOKEN=sntrys_[token]   # Vercel env only (source maps upload)

# ─────────────────────────────────────────────
# ALERTAS (dead-letter fallback)
# ─────────────────────────────────────────────
# OWNER_BACKUP_EMAIL=backup@example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
