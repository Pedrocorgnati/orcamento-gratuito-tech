# output/workspace/budget-free-tech/.env.docker.example
# Exemplo de variáveis para Docker Compose (desenvolvimento local)
# Copie para .env.docker e preencha os valores reais
#
# Para rodar: docker compose up

# ─────────────────────────────────────────────
# AMBIENTE
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# APLICACAO
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=

# ─────────────────────────────────────────────
# BANCO DE DADOS - PostgreSQL local (Docker)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=budget_free_tech_dev
DATABASE_URL=postgresql://postgres:SENHA@db:5432/budget_free_tech_dev
DIRECT_URL=postgresql://postgres:SENHA@db:5432/budget_free_tech_dev

# ─────────────────────────────────────────────
# SUPABASE (Auth + Storage)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# CRON JOBS
# ─────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=
SESSION_TTL_DAYS=7

# ─────────────────────────────────────────────
# EMAIL (Resend API)
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@orcamentogratuito.tech
