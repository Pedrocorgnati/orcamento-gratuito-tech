// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Questions & Options
// ─────────────────────────────────────────────────────────────────────────────

model Question {
  id         String  @id @default(cuid())
  code       String  @unique // "Q001", "Q010", etc.
  block      String // QuestionBlock
  type       String // QuestionType
  order      Int
  required   Boolean @default(true)
  skip_logic Json?

  options              Option[]             @relation("QuestionOptions")
  nextOptions          Option[]             @relation("NextQuestion")
  translations         QuestionTranslation[]
  sessions             Session[]            @relation("CurrentQuestion")
  answers              Answer[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([block])
  @@index([block, order])
  @@map("questions")
}

model Option {
  id                String  @id @default(cuid())
  question_id       String
  next_question_id  String?
  price_impact      Float   @default(0)
  time_impact       Float   @default(0)
  complexity_impact Float   @default(0)
  weight            Float   @default(1.0)
  order             Int

  question     Question           @relation("QuestionOptions", fields: [question_id], references: [id], onDelete: Cascade)
  nextQuestion Question?          @relation("NextQuestion", fields: [next_question_id], references: [id])
  translations OptionTranslation[]
  answers      Answer[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([question_id])
  @@index([next_question_id])
  @@map("options")
}

model QuestionTranslation {
  id          String  @id @default(cuid())
  question_id String
  locale      String // Locale
  title       String
  description String?
  help_text   String?

  question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([question_id, locale])
  @@map("question_translations")
}

model OptionTranslation {
  id          String  @id @default(cuid())
  option_id   String
  locale      String // Locale
  label       String
  description String?

  option Option @relation(fields: [option_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([option_id, locale])
  @@map("option_translations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sessions & Answers
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id                     String   @id @default(cuid())
  status                 String   @default("active") // SessionStatus
  current_question_id    String?
  project_type           String? // ProjectType
  project_types          String[] @default([])
  pending_blocks         String[] @default([])
  current_block          String?
  path_taken             Json     @default("[]")
  accumulated_price      Float    @default(0)
  accumulated_time       Float    @default(0)
  accumulated_complexity Float    @default(0)
  questions_answered     Int      @default(0)
  progress_percentage    Float    @default(0)
  locale                 String   @default("pt-BR") // Locale
  currency               String   @default("BRL") // Currency
  intermediate_email     String?
  resume_email_scheduled_for DateTime?
  resume_email_sent_at       DateTime?
  visitor_ip             String?
  user_agent             String?
  expires_at             DateTime

  // CL-250: UTM + referrer (first-touch attribution)
  utm_source             String?
  utm_medium             String?
  utm_campaign           String?
  utm_term               String?
  utm_content            String?
  referrer               String?

  currentQuestion Question? @relation("CurrentQuestion", fields: [current_question_id], references: [id])
  answers         Answer[]
  lead            Lead?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([expires_at])
  @@index([status, expires_at])
  @@index([resume_email_scheduled_for, resume_email_sent_at])
  @@map("sessions")
}

model Answer {
  id                         String  @id @default(cuid())
  session_id                 String
  question_id                String
  option_id                  String?
  text_value                 String?
  price_impact_snapshot      Float   @default(0)
  time_impact_snapshot       Float   @default(0)
  complexity_impact_snapshot Float   @default(0)
  step_number                Int

  session  Session  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id])
  option   Option?  @relation(fields: [option_id], references: [id])

  created_at DateTime @default(now())

  @@unique([session_id, question_id])
  @@index([session_id])
  @@map("answers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Leads
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id                  String    @id @default(cuid())
  session_id          String    @unique
  name                String
  email               String
  phone               String?
  company             String?
  score               String // LeadScore
  score_budget        Int
  score_timeline      Int
  score_profile       Int
  score_total         Int
  project_type        String // ProjectType
  complexity          String // ComplexityLevel
  estimated_price_min Float
  estimated_price_max Float
  estimated_days_min  Int
  estimated_days_max  Int
  features            Json
  scope_story         String    @db.Text
  locale              String
  currency            String
  consent_given       Boolean
  consent_version     String
  consent_at          DateTime
  marketing_consent   Boolean   @default(false)  // INT-091
  honeypot_triggered  Boolean   @default(false)  // SEC-010
  is_suspicious       Boolean   @default(false)  // INT-103: detecção de respostas suspeitas
  suspicious_pattern  String?                    // 'TOO_FAST' | 'TOO_UNIFORM' | 'BUDGET_MISMATCH'
  email_status        String    @default("PENDING") // EmailStatus (PENDING|SENT|FAILED|DEAD_LETTER)
  email_retry_count   Int       @default(0)
  email_sent_at       DateTime?
  last_failure_reason String?
  dead_letter_at      DateTime?
  anonymized_at       DateTime?

  // INT-024: placeholder para feedback de acurácia (V2)
  // null = não avaliado, true = estimativa precisa, false = estimativa imprecisa
  accuracy_feedback   Boolean?

  // CL-281: snapshot da versão de pesos/preços usada no cálculo
  pricing_version     String?

  // CL-113: whatsapp dedicado, separado de phone
  whatsapp            String?

  // CL-232: unsubscribe token + flag (GDPR/CAN-SPAM)
  unsubscribe_token   String    @unique @default(cuid())
  unsubscribed_at     DateTime?

  // CL-250: UTM + referrer attribution (herdado da Session no create)
  utm_source          String?
  utm_medium          String?
  utm_campaign        String?
  utm_term            String?
  utm_content         String?
  referrer            String?

  // CL-245: versao da Politica de Privacidade aceita no consent
  consent_policy_version String?

  session Session @relation(fields: [session_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([score])
  @@index([project_type])
  @@index([created_at])
  @@index([email_status])
  @@index([anonymized_at])
  @@index([email])
  @@map("leads")
}

// ─────────────────────────────────────────────────────────────────────────────
// Config & Exchange Rates
// ─────────────────────────────────────────────────────────────────────────────

// TASK-6: telemetria server-side de fluxo (abandono/retomada/alertas)
model FlowEvent {
  id          String   @id @default(cuid())
  session_id  String
  event_type  String
  block       String?
  question_id String?
  meta        Json?
  created_at  DateTime @default(now())

  @@index([event_type, created_at])
  @@index([session_id])
  @@index([block])
  @@map("flow_events")
}

model ConsistencyAlertLog {
  id         String   @id @default(cuid())
  session_id String
  alert_type String
  context    Json?
  created_at DateTime @default(now())

  @@index([alert_type, created_at])
  @@map("consistency_alert_logs")
}

// TASK-7: solicitações de direito de exclusão (LGPD/GDPR)
model ErasureRequest {
  id           String    @id @default(cuid())
  email        String
  token        String    @unique
  verified_at  DateTime?
  processed_at DateTime?
  created_at   DateTime  @default(now())

  @@index([email])
  @@map("erasure_requests")
}

model ExchangeRate {
  id            String @id @default(cuid())
  from_currency String
  to_currency   String
  rate          Float
  updated_by    String?

  updated_at DateTime @updatedAt

  @@unique([from_currency, to_currency])
  @@map("exchange_rates")
}

model PricingConfig {
  id                              String @id @default(cuid())
  project_type                    String @unique // ProjectType
  base_price                      Float
  base_days                       Int
  complexity_multiplier_low       Float  @default(1.0)
  complexity_multiplier_medium    Float  @default(1.3)
  complexity_multiplier_high      Float  @default(1.7)
  complexity_multiplier_very_high Float  @default(2.2)

  // CL-281: versão semântica dos pesos (bumpar a cada recalibração)
  version                         String @default("v1")

  updated_at DateTime @updatedAt

  @@map("pricing_configs")
}
