{
  "name": "budget-free-tech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "validate:i18n": "tsx scripts/validate-i18n.ts",
    "validate:graph": "tsx scripts/validate-decision-graph.ts",
    "validate:graph:dry": "tsx scripts/validate-decision-graph.ts --dry-run",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "bundle:analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:contracts": "vitest run src/tests/contracts",
    "test:contracts:watch": "vitest src/tests/contracts",
    "validate:seed": "tsx scripts/validate-decision-graph.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.cjs --collect.settings.preset=mobile",
    "test:performance": "npm run build && npm run lighthouse",
    "test:a11y": "playwright test tests/accessibility/ --project=chromium",
    "test:security": "playwright test tests/security/ --project=chromium",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:prod:build": "docker build -t budget-free-tech:latest .",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.10",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest-axe": "^10.0.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
